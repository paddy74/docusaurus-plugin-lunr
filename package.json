{
  "name": "docusaurus-plugin-lunr",
  "version": "3.6.0",
  "description": "Offline search component for Docusaurus V3",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "test": "mocha '**/__tests__/**/*.spec.js'",
    "format": "pnpm exec prettier . --write --config ../.prettierrc --ignore-path ../.prettierignore",
    "init": "npm install --global corepack@latest && corepack enable pnpm && corepack prepare pnpm@latest-10 --activate && pnpm install",
    "update-deps": "corepack use pnpm@latest && pnpm install && pnpm update --latest && pnpm audit --fix && pnpm install && pnpm dedupe",
    "clean-install": "pnpm store prune && rm -rf node_modules pnpm-lock.yaml && pnpm install"
  },
  "homepage": "https://github.com/paddy74/docusaurus-plugin-lunr/blob/latest/README.md",
  "repository": {
    "url": "https://github.com/paddy74/docusaurus-plugin-lunr/"
  },
  "author": {
    "name": "Praveen N",
    "url": "https://github.com/lelouch77"
  },
  "contributors": [
    {
      "name": "Pieter C",
      "url": "https://github.com/pcallewaert"
    },
    {
      "name": "ZachJW34",
      "url": "https://github.com/ZachJW34"
    },
    {
      "name": "Andrei Rublev",
      "url": "https://github.com/anru"
    },
    {
      "name": "Ris Adams",
      "url": "https://github.com/risadams"
    },
    {
      "name": "Patrick Young",
      "url": "https://github.com/paddy74"
    }
  ],
  "keywords": [
    "docusaurus",
    "lunr",
    "offline-search",
    "documentation"
  ],
  "license": "GPL3",
  "dependencies": {
    "@algolia/autocomplete-js": "^1.19.7",
    "clsx": "^2.1.1",
    "gauge": "^5.0.2",
    "hast-util-select": "^6.0.4",
    "hast-util-to-text": "^4.0.2",
    "hogan.js": "^3.0.2",
    "lunr": "^2.3.9",
    "lunr-languages": "^1.14.0",
    "mark.js": "^8.11.1",
    "minimatch": "^10.2.4",
    "rehype-parse": "^9.0.1",
    "to-vfile": "^8.0.0",
    "unified": "^11.0.5",
    "unist-util-is": "^6.0.1"
  },
  "devDependencies": {
    "@j178/prek": "^0.3.8",
    "mocha": "^11.3.0",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "@docusaurus/core": "^2.0.0-alpha.60 || ^2.0.0 || ^3.0.0",
    "react": "^16.8.4 || ^17 || ^18 || ^19",
    "react-dom": "^16.8.4 || ^17 || ^18 || ^19"
  },
  "engines": {
    "node": ">= 22.0.0"
  }
}
